# ===========================================
# Job Finder Web App - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Security (REQUIRED - Generate once)
# ===========================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here

# Secret key for session management
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# ===========================================
# LLM Configuration (Optional)
# ===========================================
# Ollama (local, free) - usually runs on default port
OLLAMA_URL=http://localhost:11434

# OpenRouter (paid, various models)
OPENROUTER_API_KEY=

# Anthropic (paid, Claude models)
ANTHROPIC_API_KEY=

# OpenAI (paid, GPT models)
OPENAI_API_KEY=

# Default model to use
DEFAULT_LLM_MODEL=ollama/llama3

# ===========================================
# App Configuration (Optional)
# ===========================================
DEBUG=true
HOST=0.0.0.0
PORT=9002

# Default timezone for new candidates
DEFAULT_TIMEZONE=Asia/Yerevan

# Data directory (defaults to ./data)
# DATA_DIR=./data

# ===========================================
# Playwright/Selenium (Optional)
# ===========================================
# Headless mode for browsers (false = visible browser)
PLAYWRIGHT_HEADLESS=false

# ===========================================
# Queue Backend (Optional - defaults to threading)
# ===========================================
# QUEUE_BACKEND=thread
# QUEUE_BACKEND=redis
# REDIS_URL=redis://localhost:6379/0
